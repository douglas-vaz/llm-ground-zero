{
  "name": "llm-ground-zero",
  "productName": "LLM Ground Zero",
  "version": "0.3.2",
  "description": "Local AI usage advisor for CLI coding agents — outcomes, spend, token reduction, and shared memory",
  "main": "main.js",
  "license": "MIT",
  "author": "Douglas Vas",
  "scripts": {
    "start": "electron .",
    "serve": "node server.js",
    "test": "node --test",
    "predist": "npm install --no-save --force @ccusage/ccusage-darwin-x64 @ccusage/ccusage-darwin-arm64",
    "dist": "electron-builder --mac --universal"
  },
  "dependencies": {
    "ccusage": "^20.0.11",
    "chart.js": "^4.4.7"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "appId": "com.douglasvaz.llm-ground-zero",
    "productName": "LLM Ground Zero",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "lib.js",
      "log.js",
      "advisor/**",
      "integrations/**",
      "static/**"
    ],
    "asarUnpack": [
      "node_modules/ccusage/**",
      "node_modules/@ccusage/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "llm-ground-zero-${version}-universal.dmg",
      "x64ArchFiles": "**/ccusage",
      "icon": "build/icon.icns"
    }
  }
}
